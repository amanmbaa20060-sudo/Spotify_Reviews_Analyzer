# Database (SQLite default — no Docker required)
DATABASE_URL=sqlite:///data/spotify_reviews.db

# Use Postgres in production / Docker environments:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/spotify_reviews

# Render production (set automatically via render.yaml fromDatabase):
# DATABASE_URL=<provided by Render Postgres — postgres://... is auto-normalized>
# APP_ENV=production
# AUTO_SEED_IF_EMPTY=true   # first deploy only: import data/raw/*.json, process, analyze

# Vercel frontend (set in Vercel Dashboard → Environment Variables)
# API_BASE_URL=https://your-service.onrender.com

# Ingestion
SPOTIFY_APP_STORE_ID=324684580
SPOTIFY_PLAY_STORE_ID=com.spotify.music
APP_STORE_MAX_PAGES=10
PLAY_STORE_DEFAULT_LIMIT=1000
REDDIT_SUBREDDITS=spotify,truespotify,spotifyplaylists
REDDIT_DEFAULT_LIMIT=1000
REDDIT_USER_AGENT=SpotifyAppReviewAnalyzer/0.1 (Growth Team)
INGEST_MAX_RETRIES=3
INGEST_BACKOFF_SECONDS=1.0
RAW_DATA_EXPORT_DIR=data/raw

# Processing (Phase 3)
CLASSIFIER_BACKEND=rule
EMBEDDING_BACKEND=tfidf
MODEL_VERSION=rule-v1.0+tfidf-v1
PROCESSING_BATCH_SIZE=100
EMBEDDING_MAX_FEATURES=256
EMBEDDING_MODEL_DIR=data/models
VALIDATION_EXPORT_DIR=data/exports
MIN_REVIEW_TEXT_LENGTH=15

# Agent / Groq (Phase 4B)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_PROMPT_VERSION=v1.0
GROQ_MAX_OUTPUT_TOKENS=2048
GROQ_MAX_CONTEXT_TOKENS=8000
GROQ_REQUESTS_PER_MINUTE=30
GROQ_REQUESTS_PER_DAY=1000
GROQ_TOKENS_PER_MINUTE=12000
GROQ_TOKENS_PER_DAY=100000
GROQ_TEMPERATURE=0.2
AGENT_LOW_CONFIDENCE_THRESHOLD=0.5
AGENT_SESSION_HISTORY_LIMIT=6

# Social ingestion (Phase 5) — Mastodon + Bluesky
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_HASHTAGS=spotify,music,Music,spotifyplaylist
MASTODON_DEFAULT_LIMIT=500
BLUESKY_SERVICE_URL=https://bsky.social
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
BLUESKY_SEARCH_QUERIES=spotify,spotify music,discover weekly,spotify playlist
BLUESKY_DEFAULT_LIMIT=500
SOCIAL_VIRAL_ENGAGEMENT_PERCENTILE=0.9
TREND_WINDOW_DAYS=7
TREND_BURST_MULTIPLIER=2.0
TREND_TOP_N=5
